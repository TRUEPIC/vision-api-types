    "validate": "tsc --noEmit --strict index.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
